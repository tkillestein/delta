#!/usr/bin/env bash
#
# delta pre-commit hook: auto-format and lint/type-check via the uv toolchain.
# Enabled by `core.hooksPath = .githooks` (see README "Development"). Runs
# ruff + ty fixes on staged Python files, restages them, then gates the commit
# on any remaining (unfixable) lint or type errors.
set -euo pipefail

# Staged, still-present Python sources (NUL-safe for odd paths).
mapfile -d '' -t PY_FILES < <(
  git diff --cached --name-only --diff-filter=ACM -z -- '*.py' '*.pyi'
)

run() { echo "pre-commit: $*"; "$@"; }

if [ ${#PY_FILES[@]} -gt 0 ]; then
  run uv run ruff check --fix -- "${PY_FILES[@]}"   # lint + import order
  run uv run ruff format -- "${PY_FILES[@]}"        # formatting
  git add -- "${PY_FILES[@]}"                        # restage fixes
fi

# Type-check the project; --fix applies what it can, exit code gates the rest.
run uv run ty check --fix

# ty may have touched staged files; restage them so the fixes are committed.
if [ ${#PY_FILES[@]} -gt 0 ]; then
  git add -- "${PY_FILES[@]}"
fi
